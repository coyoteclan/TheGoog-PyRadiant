/* Forest Green Theme for CoD1 Radiant Editor */

QMainWindow, QDialog {
    background-color: #1a261a;
    color: #d8e8d8;
}
QMenuBar {
    background-color: #243824;
    color: #d8e8d8;
    border-bottom: 1px solid #3a5a3a;
}
QMenuBar::item {
    background-color: transparent;
    padding: 4px 8px;
}
QMenuBar::item:selected {
    background-color: #3a5a3a;
}
QMenuBar::item:pressed {
    background-color: #4a8a4a;
}
QMenu {
    background-color: #1a261a;
    color: #d8e8d8;
    border: 1px solid #3a5a3a;
}
QMenu::item {
    padding: 6px 24px 6px 24px;
}
QMenu::item:selected {
    background-color: #4a8a4a;
}
QMenu::separator {
    height: 1px;
    background-color: #3a5a3a;
    margin: 4px 8px;
}
QToolBar {
    background-color: #243824;
    border: none;
    spacing: 3px;
    padding: 3px;
}
QToolBar::separator {
    background-color: #3a5a3a;
    width: 1px;
    margin: 4px 6px;
}
QToolButton {
    background-color: transparent;
    color: #d8e8d8;
    border: 1px solid transparent;
    border-radius: 3px;
    padding: 4px 8px;
}
QToolButton:hover {
    background-color: #3a5a3a;
    border: 1px solid #4a6a4a;
}
QToolButton:pressed {
    background-color: #4a8a4a;
}
QDockWidget {
    color: #d8e8d8;
    titlebar-close-icon: url(none);
    titlebar-normal-icon: url(none);
}
QDockWidget::title {
    background-color: #243824;
    padding: 6px;
    border-bottom: 1px solid #3a5a3a;
}
QDockWidget::close-button, QDockWidget::float-button {
    background-color: transparent;
    border: none;
}
QDockWidget::close-button:hover, QDockWidget::float-button:hover {
    background-color: #3a5a3a;
}
QStatusBar {
    background-color: #243824;
    color: #d8e8d8;
    border-top: 1px solid #3a5a3a;
}
QStatusBar::item {
    border: none;
}
QLabel {
    color: #d8e8d8;
}
QGroupBox {
    color: #d8e8d8;
    border: 1px solid #3a5a3a;
    border-radius: 4px;
    margin-top: 8px;
    padding-top: 8px;
}
QGroupBox::title {
    subcontrol-origin: margin;
    subcontrol-position: top left;
    padding: 0 4px;
    color: #d8e8d8;
}
QPushButton {
    background-color: #2a4a2a;
    color: #d8e8d8;
    border: 1px solid #3a5a3a;
    border-radius: 4px;
    padding: 6px 16px;
}
QPushButton:hover {
    background-color: #3a5a3a;
    border: 1px solid #4a6a4a;
}
QPushButton:pressed {
    background-color: #4a8a4a;
}
QPushButton:disabled {
    background-color: #1a261a;
    color: #5a6a5a;
}
QLineEdit, QSpinBox, QDoubleSpinBox, QComboBox {
    background-color: #0f180f;
    color: #d8e8d8;
    border: 1px solid #3a5a3a;
    border-radius: 3px;
    padding: 4px;
}
QLineEdit:focus, QSpinBox:focus, QDoubleSpinBox:focus, QComboBox:focus {
    border: 1px solid #4a8a4a;
}
QComboBox::drop-down {
    border: none;
    width: 20px;
}
QComboBox::down-arrow {
    image: none;
    border-left: 4px solid transparent;
    border-right: 4px solid transparent;
    border-top: 6px solid #d8e8d8;
    margin-right: 6px;
}
QComboBox QAbstractItemView {
    background-color: #1a261a;
    color: #d8e8d8;
    border: 1px solid #3a5a3a;
    selection-background-color: #4a8a4a;
}
QCheckBox {
    color: #d8e8d8;
    spacing: 6px;
}
QCheckBox::indicator {
    width: 16px;
    height: 16px;
    border: 1px solid #3a5a3a;
    border-radius: 3px;
    background-color: #0f180f;
}
QCheckBox::indicator:checked {
    background-color: #4a8a4a;
    border: 1px solid #4a8a4a;
}
QTabWidget::pane {
    border: 1px solid #3a5a3a;
    background-color: #1a261a;
}
QTabBar::tab {
    background-color: #243824;
    color: #d8e8d8;
    border: 1px solid #3a5a3a;
    padding: 6px 16px;
    margin-right: 2px;
}
QTabBar::tab:selected {
    background-color: #1a261a;
    border-bottom: none;
}
QTabBar::tab:hover:!selected {
    background-color: #3a5a3a;
}
QScrollBar:vertical {
    background-color: #1a261a;
    width: 12px;
    border: none;
}
QScrollBar::handle:vertical {
    background-color: #3a5a3a;
    border-radius: 4px;
    min-height: 20px;
    margin: 2px;
}
QScrollBar::handle:vertical:hover {
    background-color: #4a6a4a;
}
QScrollBar::add-line:vertical, QScrollBar::sub-line:vertical {
    height: 0px;
}
QScrollBar:horizontal {
    background-color: #1a261a;
    height: 12px;
    border: none;
}
QScrollBar::handle:horizontal {
    background-color: #3a5a3a;
    border-radius: 4px;
    min-width: 20px;
    margin: 2px;
}
QScrollBar::handle:horizontal:hover {
    background-color: #4a6a4a;
}
QScrollBar::add-line:horizontal, QScrollBar::sub-line:horizontal {
    width: 0px;
}
QTableWidget {
    background-color: #0f180f;
    color: #d8e8d8;
    gridline-color: #3a5a3a;
    border: 1px solid #3a5a3a;
}
QTableWidget::item {
    padding: 4px;
}
QTableWidget::item:selected {
    background-color: #4a8a4a;
}
QHeaderView::section {
    background-color: #243824;
    color: #d8e8d8;
    padding: 6px;
    border: none;
    border-right: 1px solid #3a5a3a;
    border-bottom: 1px solid #3a5a3a;
}
QSplitter::handle {
    background-color: #243824;
}
QSplitter::handle:horizontal {
    width: 4px;
}
QSplitter::handle:vertical {
    height: 4px;
}
QWidget {
    background-color: #1a261a;
    color: #d8e8d8;
}
QListWidget {
    background-color: #0f180f;
    color: #d8e8d8;
    border: 1px solid #3a5a3a;
}
QListWidget::item {
    padding: 4px;
    color: #d8e8d8;
}
QListWidget::item:selected {
    background-color: #4a8a4a;
    color: #ffffff;
}
QListWidget::item:hover:!selected {
    background-color: #243824;
}
QTreeWidget {
    background-color: #0f180f;
    color: #d8e8d8;
    border: 1px solid #3a5a3a;
    alternate-background-color: #0f180f;
}
QTreeWidget::item {
    padding: 4px;
    color: #d8e8d8;
    background-color: #0f180f;
}
QTreeWidget::item:selected {
    background-color: #4a8a4a;
    color: #ffffff;
}
QTreeWidget::item:hover:!selected {
    background-color: #243824;
}
QTreeWidget::branch {
    background-color: #0f180f;
}
QTreeWidget QHeaderView::section {
    background-color: #243824;
    color: #d8e8d8;
    padding: 4px;
    border: none;
    border-right: 1px solid #3a5a3a;
    border-bottom: 1px solid #3a5a3a;
}
QScrollArea {
    background-color: #1a261a;
    border: none;
}
QFrame {
    color: #3a5a3a;
}
